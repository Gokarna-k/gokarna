pipeline {
    agent any

    stages {

        stage('Fetching Code From GitHub') {
            steps {
                git branch: 'dev',
                    url: 'https://github.com/Gokarna-k/gokarna.git'
            }
        }

        stage('Build Phase') {
            steps {
                sh 'mvn clean install'
            }
        }

        stage('Test Phase') {
            steps {
                echo 'Running tests...'
            }
        }

        stage('Deploy Phase') {
            steps {
                echo 'Application deployed'
            }
        }
    }
}

